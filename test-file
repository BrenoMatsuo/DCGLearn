const jwt = require('jsonwebtoken');

// Kiểm tra xem người dùng đã đăng nhập (có token) chưa
exports.verifyToken = (req, res, next) => {
    const token = req.headers['authorization'];

    if (!token) {
        return res.status(403).json({ message: 'Cần cung cấp token!' });
    }

    try {
        // Cắt bỏ chữ "Bearer " để lấy token thật
        const decoded = jwt.verify(token.split(" ")[1], process.env.JWT_SECRET);
        req.user = decoded; // Lưu thông tin user vào request để các hàm sau dùng
        next(); // Cho phép đi tiếp
    } catch (err) {
        return res.status(401).json({ message: 'Token không hợp lệ!' });
    }
};

// Kiểm tra quyền (Role)
exports.checkRole = (roles) => {
    return (req, res, next) => {
        // req.user.role được lấy ra từ verifyToken ở trên
        if (!roles.includes(req.user.role)) {
            return res.status(403).json({ message: 'Bạn không có quyền thực hiện hành động này!' });
        }
        next();
    };
};



